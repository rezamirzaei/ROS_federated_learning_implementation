{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Controller state",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "PROM"},
      "targets": [
        {"expr": "fl_controller_state", "legendFormat": "{{state}}"}
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green"}]}
        }
      }
    },
    {
      "type": "stat",
      "title": "Robots",
      "gridPos": {"h": 4, "w": 3, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "PROM"},
      "targets": [{"expr": "fl_robot_count"}]
    },
    {
      "type": "stat",
      "title": "Rounds completed",
      "gridPos": {"h": 4, "w": 3, "x": 9, "y": 0},
      "datasource": {"type": "prometheus", "uid": "PROM"},
      "targets": [{"expr": "fl_aggregation_rounds_total"}]
    },
    {
      "type": "gauge",
      "title": "Average accuracy (%)",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "PROM"},
      "targets": [{"expr": "fl_avg_accuracy"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
    },
    {
      "type": "gauge",
      "title": "Best accuracy (%)",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "PROM"},
      "targets": [{"expr": "fl_best_accuracy"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
    },
    {
      "type": "timeseries",
      "title": "Loss vs accuracy",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "PROM"},
      "targets": [
        {"expr": "fl_avg_loss", "legendFormat": "avg_loss"},
        {"expr": "fl_avg_accuracy / 100", "legendFormat": "avg_accuracy"}
      ]
    },
    {
      "type": "timeseries",
      "title": "MPC mean tracking error (m)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "PROM"},
      "targets": [{"expr": "fl_mean_tracking_error"}]
    },
    {
      "type": "timeseries",
      "title": "Round latency (seconds, p50/p90/p99)",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "PROM"},
      "targets": [
        {"expr": "histogram_quantile(0.5, rate(fl_round_latency_seconds_bucket[5m]))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.9, rate(fl_round_latency_seconds_bucket[5m]))", "legendFormat": "p90"},
        {"expr": "histogram_quantile(0.99, rate(fl_round_latency_seconds_bucket[5m]))", "legendFormat": "p99"}
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["fl-robots", "federated-learning"],
  "templating": {"list": []},
  "time": {"from": "now-15m", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "FL-Robots",
  "uid": "fl-robots-main",
  "version": 1,
  "weekStart": ""
